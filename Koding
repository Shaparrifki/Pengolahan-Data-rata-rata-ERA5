import xarray as xr
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from climate_indices import indices, compute

# 1. Buka file NetCDF
ds = xr.open_dataset('/content/drive/MyDrive/MBKM/Data ERA5/data_rata-rata_30th_Cilacap.nc')

# Print the dataset to inspect its contents and variable names
print(ds)

# 2. Ekstrak data untuk koordinat Cilacap (sekitar -7.72, 109.01)
# method='nearest' akan mencari grid terdekat dari koordinat tersebut
cilacap_data = ds.tp.sel(latitude=-7.72, longitude=109.01, method='nearest').to_dataframe()

# 3. Konversi Satuan: m/day ke mm/month
# Kita ambil jumlah hari tiap bulan dari index waktu
cilacap_data['days_in_month'] = cilacap_data.index.days_in_month
cilacap_data['precip_mm'] = cilacap_data['tp'] * 1000 * cilacap_data['days_in_month']

# 4. Hitung SPI (Misal SPI-3)
# Library climate-indices butuh data dalam bentuk numpy array
spi_3 = indices.spi(
    cilacap_data['precip_mm'].values,
    scale=3,
    distribution=indices.Distribution.gamma,
    data_start_year=1996, # Sesuaikan dengan tahun awal data kamu
    calibration_year_initial=1996,
    calibration_year_final=2025, # Sesuaikan dengan tahun akhir data
    periodicity=compute.Periodicity.monthly
)

cilacap_data['SPI_3'] = spi_3

# 5. Visualisasi Grafik
plt.figure(figsize=(12, 6))
colors = ['red' if x < 0 else 'blue' for x in cilacap_data['SPI_3']]
plt.bar(cilacap_data.index, cilacap_data['SPI_3'], color=colors, width=20)

# Tambahkan garis bantu
plt.axhline(y=0, color='black', linestyle='-', linewidth=1)
plt.axhline(y=-1, color='yellow', linestyle='--', label='Kekeringan Sedang')
plt.axhline(y=-1.5, color='orange', linestyle='--', label='Kekeringan Parah')
plt.axhline(y=-2, color='red', linestyle='--', label='Kekeringan Ekstrem')

plt.title('Indeks Kekeringan SPI-3 Wilayah Cilacap (1996-2025)')
plt.ylabel('Nilai SPI')
plt.xlabel('Tahun')
plt.legend()
plt.grid(alpha=0.3)
plt.show()
